  "name": "optimal_safe_collective_learning_loop_controls",
  "summary": "Executable control contract for Borg safe collective learning. Remote/global/federated protocol is GO for signed hosted-registry propagation and revocation; public self-serve and external-user lift remain separate NO-GO claims.",
  "go_no_go": {
    "local_learning_atom_primitive": "GO",
    "shared_store_import_path": "GO_AFTER_HARDENING",
    "staging_a_to_b_propagation": "GO_LOCAL_FILESYSTEM_STAGING",
    "global_federated_learning_claim": "GO_REMOTE_SIGNED_PROTOCOL_ONLY",
    "google_god_tier_learning_optimality": "NO_GO_VALUE_LOOP_NOT_PROVEN",
    "public_self_serve_launch": "NO_GO_FIRST_10_EXTERNAL_EVIDENCE_NOT_PROVEN",
    "external_user_lift_claim": "NO_GO_NO_CONSENTED_OUTCOME_ROWS"
  },
  "controls": [
    {
      "id": "CLC-001",
      "priority": "P0",
      "category": "privacy_boundary",
      "invariant": "Raw traces, raw prompts, source files, tool outputs, env vars, screenshots, and tenant identifiers are not accepted as shared memory.",
      "implementation_files": [
        "borg/core/learning_atoms.py",
        "borg/core/privacy.py"
      ],
      "tests": [
        "tests/security/test_learning_atoms.py",
        "tests/security/test_privacy_structured.py"
      ],
      "status": "implemented_local"
    },
    {
      "id": "CLC-002",
      "priority": "P0",
      "category": "signature_integrity",
      "invariant": "Every shared atom must be inside a valid signed learning-atom envelope before store/import/publish acceptance.",
      "implementation_files": [
        "borg/core/learning_atoms.py",
        "borg/core/atom_store.py",
        "borg/core/publish.py"
      ],
      "tests": [
        "tests/security/test_learning_atoms.py",
        "tests/security/test_atom_store.py",
        "tests/security/test_learning_atom_publish.py"
      ],
      "status": "implemented_local"
    },
    {
      "id": "CLC-003",
      "priority": "P0",
      "category": "identity_binding",
      "invariant": "signature.key_id and payload.trust.submitter_key_id must equal the key id derived from the Ed25519 verify key.",
      "implementation_files": [
        "borg/core/learning_atoms.py"
      ],
      "tests": [
        "tests/security/test_learning_atoms.py"
      ],
      "status": "implemented_local"
    },
    {
      "id": "CLC-004",
      "priority": "P0",
      "category": "quorum_sybil_resistance",
      "invariant": "Global promotion cannot rely on self-declared independent_tenant_count from the atom payload; quorum must be registry-computed.",
      "implementation_files": [
        "borg/core/atom_policy.py",
        "borg/core/atom_store.py",
        "borg/core/atom_retrieval.py"
      ],
      "tests": [
        "tests/security/test_atom_policy.py",
        "tests/security/test_atom_store.py",
        "tests/security/test_atom_retrieval_firewall.py"
      ],
      "status": "implemented_policy_gate"
    },
    {
      "id": "CLC-005",
      "priority": "P0",
      "category": "prompt_injection",
      "invariant": "Prompt-injection and retrieval-poisoning payloads are blocked or neutralized before appearing in agent retrieval context.",
      "implementation_files": [
        "borg/core/prompt_injection.py",
        "borg/core/atom_retrieval.py"
      ],
      "tests": [
        "tests/security/test_prompt_injection.py",
        "tests/security/test_atom_retrieval_firewall.py"
      ],
      "status": "implemented_local"
    },
    {
      "id": "CLC-006",
      "priority": "P0",
      "category": "revocation",
      "invariant": "Tombstone wins over get/search/re-import for revoked atoms.",
      "implementation_files": [
        "borg/core/atom_store.py"
      ],
      "tests": [
        "tests/security/test_atom_store.py"
      ],
      "status": "implemented_local"
    },
    {
      "id": "CLC-007",
      "priority": "P0",
      "category": "concurrency",
      "invariant": "Concurrent failure-memory writes preserve all increments and do not collide on fixed temporary paths.",
